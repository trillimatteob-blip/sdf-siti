{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "rootDir": "."
  },
  "include": ["**/*.ts"],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  }
}
